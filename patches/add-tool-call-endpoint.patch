#!/usr/bin/env node

/**
 * 添加工具调用API端点的补丁脚本
 *
 * 由于检查发现编排器服务器中已有 /v1/orchestrate-tool-calls 端点，
 * 但可能存在实现不完整的情况，这个脚本将确保功能正确实现
 */

const fs = require('fs');
const path = require('path');

// 要修改的文件路径
const serverFilePath = path.join(__dirname, '..', 'src', 'orchestrator', 'OrchestratorServer.js');

console.log('🔍 检查编排器服务器中的工具调用端点实现...');

// 读取服务器文件
const serverContent = fs.readFileSync(serverFilePath, 'utf8');

// 检查是否已经有工具调用端点实现
const hasToolCallEndpoint = serverContent.includes('/v1/orchestrate-tool-calls');
const hasFormatMethod = serverContent.includes('_formatResponseForClaudeCode');

console.log(`📋 工具调用端点存在: ${hasToolCallEndpoint}`);
console.log(`📋 格式化方法存在: ${hasFormatMethod}`);

if (!hasToolCallEndpoint) {
  console.log('⚠️  工具调用端点未找到，正在添加...');

  // 查找适当的位置插入新的端点处理代码
  const insertPosition = serverContent.indexOf('// 编排端点 - 接收 Claude Code 的请求');

  if (insertPosition !== -1) {
    // 获取插入位置之前的代码
    const beforeInsert = serverContent.substring(0, insertPosition);
    const afterInsert = serverContent.substring(insertPosition);

    // 新的工具调用端点处理代码
    const newEndpointCode = `
      // 新增工具调用格式编排端点 - 为 Claude Code 生成可执行的工具调用格式
      if (pathname === '/v1/orchestrate-tool-calls' || pathname === '/orchestrate-tool-calls') {
        if (req.method !== 'POST') {
          return this._sendJSON(res, 405, { error: 'Method not allowed' });
        }

        const requestBody = await this._parseBody(req);
        this._log(\`收到 Claude Code 工具调用格式请求，消息长度：\${JSON.stringify(requestBody).length}\`);

        try {
          // 判断是否需要任务分解
          if (this.config.autoOrchestrate && await this._shouldDecompose(requestBody)) {
            this._log('检测到复杂任务，启动编排流程');

            // 执行编排（包含分解器调用）
            const orchestrateResult = await this._orchestrate(requestBody);

            // 格式化编排结果
            let formattedResult = this._formatOrchestrationResult(orchestrateResult, requestBody);

            // 应用 Token 限制处理
            const maxTokens = this.config.tokenLimit || 8000;
            formattedResult = this._handleTokenLimit(formattedResult, maxTokens);

            // 格式化为工具调用格式
            const finalOutput = this._formatResponseForClaudeCode(orchestrateResult, requestBody, 'tool_call');

            return this._sendJSON(res, 200, finalOutput);

          } else {
            this._log('普通任务，转发给 CCR Router');

            // 转发给 CCR Router
            const ccrResult = await this._forwardToCCR(requestBody, req.headers);

            return this._sendJSON(res, ccrResult.statusCode, ccrResult.body);
          }
        } catch (error) {
          this._log(\`编排流程失败：\${error.message}\`, 'error');
          return this._sendJSON(res, 500, {
            error: '编排流程失败',
            message: error.message,
            stack: this.config.debug ? error.stack : undefined
          });
        }
      }

`;

    // 组合新代码
    const updatedContent = beforeInsert + newEndpointCode + afterInsert;

    // 写回文件
    fs.writeFileSync(serverFilePath, updatedContent);
    console.log('✅ 工具调用端点已添加到服务器');
  } else {
    console.log('❌ 未找到合适位置插入端点代码');
  }
} else {
  console.log('✅ 工具调用端点已存在');
}

// 检查并可能需要更新_formatResponseForClaudeCode方法
if (!hasFormatMethod) {
  console.log('⚠️  格式化方法未找到，正在添加...');

  // 这里会查找适当的位置添加_formatResponseForClaudeCode方法
  // 但为了避免复杂补丁操作，我们只输出提醒
  console.log('⚠️  请注意：_formatResponseForClaudeCode方法未找到，可能需要手动实现');
} else {
  console.log('✅ 格式化方法已存在');
}

console.log('🔧 工具调用端点补丁完成');