    "rate_limit": {
      "default_rps": 10,
      "burst_capacity": 30,
      "enable_coordination": true,
      "health_check_factor": 0.1,
      "per_model": {}
    },
    "cost_control": {
      "default_budget": 100,
      "safety_margin": 0.2,
      "conservative_estimation": true,
      "enable_real_time_tracking": true
    },
    "tracing": {
      "enabled": true,
      "log_level": "info",
      "include_sensitive_data": false,
      "sampling_rate": 1,
      "max_traces": 10000
    },
    "monitoring": {
      "enabled": true,
      "metrics_collection": true,
      "performance_logging": true,
      "alert_thresholds": {
        "error_rate": 0.05,
        "response_time": 5000,
        "resource_usage": 0.8
      }
    },
    "model_specific": {},
    "fallback_strategy": {
      "timeout": {
        "enabled": true,
        "max_attempts": 3,
        "timeout_per_attempt": 30000,
        "backoff_multiplier": 1.5
      },
      "budget": {
        "enabled": true,
        "max_cost_reduction": 0.5,
        "alternative_search_depth": 5
      },
      "availability": {
        "enabled": true,
        "retry_on_unavailability": true,
        "max_fallback_models": 3
      },
      "global": {
        "max_total_fallbacks": 5,
        "enable_chained_fallbacks": true,
        "log_level": "info"
      }
    },
    "health_check": {
      "interval": 60000,
      "timeout": 5000,
      "enabled": true
    },
    "system_coordinator": {
      "cpu_threshold_high": 0.7,
      "cpu_threshold_critical": 0.9,
      "memory_threshold_high": 0.7,
      "memory_threshold_critical": 0.9,
      "check_interval": 10000
    },
    "repair": {
      "$comment": "修复机制配置 - 代码执行失败后的自动修复功能",
      "enabled": true,
      "max_local_repair_attempts": 3,
      "max_cloud_repair_attempts": 2,
      "repair_timeout": 30000,
      "local_repair_delay": 1000,
      "cloud_repair_delay": 3000,
      "enable_auto_repair": true,
      "default_repair_model": "MiniMax-M2.7",
      "error_classification": {
        "simple_error_patterns": [
          "SyntaxError",
          "ReferenceError",
          "TypeError"
        ],
        "moderate_error_patterns": [
          "Error:",
          "Exception:",
          "undefined is not"
        ],
        "complex_error_patterns": [
          "Error:",
          "ENOENT",
          "EADDRINUSE"
        ]
      }
    }
  },
