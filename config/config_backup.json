    "webSearch": "deepseek,deepseek-chat",
    "image": "deepseek,deepseek-chat",
    "code": "minimax,MiniMax-M2.5",
    "reasoning": "deepseek,deepseek-reasoner",
    "selectionRules": [],

    "$comment_selector_constraints": "---------------------------------------- 选择器约束配置 ----------------------------------------",
    "max_cost_per_task": 0.5,
    "daily_budget": 10.00,
    "preferred_providers": ["minimax", "deepseek", "bailian"],
    "quality_first": false,

    "$comment_selector_fallback": "---------------------------------------- 选择器降级策略 ----------------------------------------",
    "fallback": {
      "max_fallback_depth": 2,
      "error_rate_threshold": 0.3,
      "latency_threshold_ms": 5000,
      "rate_limit_threshold": 10
    },

    "$comment_selector_monitoring": "---------------------------------------- 选择器监控配置 ----------------------------------------",
    "monitoring": {
      "enabled": true,
      "status_check_interval": 60000,
      "log_selection_reason": true,
      "track_performance": true,
      "max_history_size": 1000
    },

    "$comment_selector_strategy": "---------------------------------------- 选择器策略配置 ----------------------------------------",
    "strategy": {
      "enable_learning": true,
      "learning_window": 100,
      "quality_weight": 0.4,
      "cost_weight": 0.4,
      "speed_weight": 0.2,
      "learning_integration": {
        "strategy": "hybrid",
        "rule_weight": 0.6,
        "learning_weight": 0.4,
        "min_learning_confidence": 0.7,
        "contextual_switching": {
          "enabled": true,
          "conditions": {
            "high_uncertainty_tasks": true,
            "security_critical": true,
            "repetitive_tasks": true,
            "performance_sensitive": true
          }
        }
      }
    }
  },
  "$comment_costControl": "---------------------------------------- 【成本控制】- API 调用成本控制 ----------------------------------------",
