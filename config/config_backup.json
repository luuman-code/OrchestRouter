  "$comment_selector": "---------------------------------------- 【模型选择】- 模型选择规则配置 ----------------------------------------",
  "selector": {
    "default": "deepseek,deepseek-chat",
    "background": "minimax,MiniMax-M2.5",
    "think": "deepseek,deepseek-reasoner",
    "longContext": "minimax,MiniMax-M2.5",
