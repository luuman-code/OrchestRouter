            "typical_file_extensions": []
          }
        }
      },
      "custom": {}
    },
    "matching_rules": {
      "keyword_rules": [
        {
          "id": "kw-ui-001",
          "type": "ui",
          "keywords": [
            "组件",
            "component",
            "ui",
            "界面",
            "页面",
            "view",
            "render"
          ],
          "weight": 0.8,
          "match_mode": "any"
        },
        {
          "id": "kw-style-001",
          "type": "style",
          "keywords": [
            "样式",
            "style",
            "css",
            "scss",
            "美观",
            "视觉"
          ],
          "weight": 0.75,
          "match_mode": "any"
        },
        {
          "id": "kw-api-001",
          "type": "api",
          "keywords": [
            "api",
            "接口",
            "endpoint",
            "route",
            "请求",
            "response"
          ],
          "weight": 0.8,
          "match_mode": "any"
        },
        {
          "id": "kw-model-001",
          "type": "model",
          "keywords": [
            "模型",
            "model",
            "entity",
            "schema",
            "数据库",
            "table"
          ],
          "weight": 0.85,
          "match_mode": "any"
        },
        {
          "id": "kw-test-001",
          "type": "test",
          "keywords": [
            "测试",
            "test",
            "unit",
            "spec",
            "断言",
            "assert"
          ],
          "weight": 0.9,
          "match_mode": "any"
        }
      ],
      "file_path_rules": [
        {
          "id": "fp-ui-001",
          "type": "ui",
          "patterns": [
            "**/components/**/*",
            "**/pages/**/*",
            "**/views/**/*"
          ],
          "weight": 0.9
        },
        {
          "id": "fp-style-001",
          "type": "style",
          "patterns": [
            "**/*.css",
            "**/*.scss",
            "**/*.sass",
            "**/*.module.css"
          ],
          "weight": 0.95
        },
        {
          "id": "fp-api-001",
          "type": "api",
          "patterns": [
            "**/api/**/*",
            "**/routes/**/*",
            "**/controllers/**/*"
          ],
          "weight": 0.9
        },
        {
          "id": "fp-model-001",
          "type": "model",
          "patterns": [
            "**/models/**/*",
            "**/entities/**/*",
            "**/schemas/**/*"
          ],
          "weight": 0.9
        }
      ],
      "regex_rules": [
        {
          "id": "rx-test-001",
          "type": "test",
          "patterns": [
            "\\.test\\.",
            "\\.spec\\.",
            "describe\\(|it\\(|test\\("
          ],
          "weight": 0.95,
          "flags": "i"
        }
      ]
    },
    "plugins": {
      "paths": [
        "./plugins",
        "./src/decomposer/plugins/built-in"
      ],
      "enabled": [],
      "configs": {}
    },
    "semantic_analysis": {
      "merge_threshold": 0.7,
      "dependency_threshold": 0.3,
      "weights": {
        "content": 0.5,
        "type": 0.3,
        "context": 0.2
      },
      "algorithm": "tfidf_cosine",
      "stop_words": [
        "的",
        "了",
        "是",
        "在",
        "和",
        "与",
        "及",
        "等",
        "a",
        "an",
        "the",
        "is",
        "are",
        "was",
        "were",
        "be",
        "been",
        "to",
        "for",
        "with",
        "on",
        "at",
        "from",
        "by"
      ]
    },
    "debug": {
      "enabled": false,
      "log_level": "info",
      "max_history": 100,
      "performance_tracking": true,
      "memory_tracking": false
