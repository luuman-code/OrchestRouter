  "costControl": {
    "dailyBudget": 10.00,
    "maxCostPerTask": 0.50,
    "qualityFirst": false,
    "safetyMargin": 0.2,
    "conservativeEstimation": true
  },

  "executor": {
    "defaultMaxConcurrency": 10,
    "defaultTimeout": 60000,
    "enableTracing": true,
    "enableMonitoring": true,
    "retry": {
      "maxRetries": 3,
      "baseDelay": 1000,
      "exponentialBase": 2.0,
      "jitter": true
    },
    "rateLimit": {
      "defaultRps": 10,
      "burstCapacity": 30
    }
  }
