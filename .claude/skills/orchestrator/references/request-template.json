      },
      {
        "filePath": "server/database/db.ts",
        "types": [
          { "dimension": "category", "value": "backend", "weight": 0.9 },
          { "dimension": "complexity", "value": "medium", "weight": 0.7 }
        ],
        "description": "数据库初始化和模型定义",
