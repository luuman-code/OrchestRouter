    },
    "taskComplexityAnalysis": {
      "enabled": true,
      "useLLM": true,
      "confidenceThresholds": {
        "high": 0.8,
        "medium": 0.5
      },
      "llmConfig": {
        "base_url": "http://localhost:11434",
        "model": "qwen2.5:3b",
        "timeout": 30000,
        "temperature": 0.1,
        "maxTokens": 500
      },
      "fallback": {
        "onLLMError": "rule_based",
        "cacheEnabled": true,
        "cacheExpiration": 3600000
      }
    }
  }
