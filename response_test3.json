{"content":[{"type":"tool_use","id":"write_file_9codih9gqjdoaz7mj7kdtc","name":"write_file","input":{"file_path":"index.html","content":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>NBA选秀数据分析</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);\n            min-height: 100vh;\n            color: #fff;\n            padding: 20px;\n        }\n\n        .container {\n            max-width: 1400px;\n            margin: 0 auto;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 40px;\n            padding: 30px;\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 20px;\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        h1 {\n            font-size: 2.5rem;\n            background: linear-gradient(135deg, #e94560, #f39c12);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            background-clip: text;\n            margin-bottom: 10px;\n        }\n\n        .subtitle {\n            color: #a0a0a0;\n            font-size: 1.1rem;\n        }\n\n        .stats-container {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n            gap: 20px;\n            margin-bottom: 30px;\n        }\n\n        .stat-card {\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 15px;\n            padding: 25px;\n            text-align: center;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            transition: transform 0.3s, box-shadow 0.3s;\n        }\n\n        .stat-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 10px 30px rgba(233, 69, 96, 0.2);\n        }\n\n        .stat-card h3 {\n            font-size: 0.9rem;\n            color: #a0a0a0;\n            margin-bottom: 10px;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n        }\n\n        .stat-card .value {\n            font-size: 2.5rem;\n            font-weight: bold;\n            background: linear-gradient(135deg, #e94560, #f39c12);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            background-clip: text;\n        }\n\n        .filters {\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 15px;\n            padding: 25px;\n            margin-bottom: 30px;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        .filters-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n            gap: 15px;\n        }\n\n        .filter-group {\n            display: flex;\n            flex-direction: column;\n        }\n\n        .filter-group label {\n            margin-bottom: 8px;\n            color: #a0a0a0;\n            font-size: 0.9rem;\n        }\n\n        .filter-group select,\n        .filter-group input {\n            padding: 12px 15px;\n            border-radius: 10px;\n            border: 1px solid rgba(255, 255, 255, 0.2);\n            background: rgba(255, 255, 255, 0.05);\n            color: #fff;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: border-color 0.3s;\n        }\n\n        .filter-group select:focus,\n        .filter-group input:focus {\n            outline: none;\n            border-color: #e94560;\n        }\n\n        .filter-group select option {\n            background: #1a1a2e;\n        }\n\n        .table-container {\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 15px;\n            overflow: hidden;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        table {\n            width: 100%;\n            border-collapse: collapse;\n        }\n\n        thead {\n            background: rgba(233, 69, 96, 0.2);\n        }\n\n        th {\n            padding: 18px 15px;\n            text-align: left;\n            font-weight: 600;\n            color: #e94560;\n            text-transform: uppercase;\n            font-size: 0.85rem;\n            letter-spacing: 1px;\n            cursor: pointer;\n            transition: background 0.3s;\n            user-select: none;\n        }\n\n        th:hover {\n            background: rgba(233, 69, 96, 0.3);\n        }\n\n        th .sort-icon {\n            margin-left: 5px;\n            opacity: 0.5;\n        }\n\n        th.sorted .sort-icon {\n            opacity: 1;\n        }\n\n        tbody tr {\n            border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n            transition: background 0.3s;\n        }\n\n        tbody tr:hover {\n            background: rgba(233, 69, 96, 0.1);\n        }\n\n        td {\n            padding: 15px;\n            font-size: 0.95rem;\n        }\n\n        .pick-number {\n            font-weight: bold;\n            color: #f39c12;\n        }\n\n        .player-name {\n            font-weight: 600;\n            color: #fff;\n        }\n\n        .player-name .position {\n            color: #a0a0a0;\n            font-weight: normal;\n            font-size: 0.85rem;\n            margin-left: 8px;\n        }\n\n        .team-name {\n            color: #3498db;\n        }\n\n        .college {\n            color: #a0a0a0;\n        }\n\n        .stats-cell {\n            display: flex;\n            gap: 15px;\n            flex-wrap: wrap;\n        }\n\n        .stat-item {\n            text-align: center;\n            min-width: 50px;\n        }\n\n        .stat-item .label {\n            font-size: 0.75rem;\n            color: #a0a0a0;\n            text-transform: uppercase;\n        }\n\n        .stat-item .value {\n            font-size: 1.1rem;\n            font-weight: bold;\n            color: #f39c12;\n        }\n\n        .pagination {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            gap: 10px;\n            margin-top: 25px;\n            padding: 20px;\n        }\n\n        .pagination button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 10px;\n            background: rgba(233, 69, 96, 0.2);\n            color: #fff;\n            cursor: pointer;\n            transition: all 0.3s;\n            font-size: 0.95rem;\n        }\n\n        .pagination button:hover:not(:disabled) {\n            background: #e94560;\n        }\n\n        .pagination button:disabled {\n            opacity: 0.5;\n            cursor: not-allowed;\n        }\n\n        .pagination .page-info {\n            color: #a0a0a0;\n            padding: 10px 20px;\n        }\n\n        .no-data {\n            text-align: center;\n            padding: 60px;\n            color: #a0a0a0;\n        }\n\n        .no-data h3 {\n            margin-bottom: 10px;\n        }\n\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 1.8rem;\n            }\n\n            .stats-container {\n                grid-template-columns: repeat(2, 1fr);\n            }\n\n            table {\n                font-size: 0.85rem;\n            }\n\n            th, td {\n                padding: 10px 8px;\n            }\n\n            .stats-cell {\n                gap: 8px;\n            }\n\n            .stat-item {\n                min-width: 40px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>🏀 NBA选秀数据分析</h1>\n            <p class=\"subtitle\">2020-2024年NBA选秀数据可视化与分析</p>\n        </header>\n\n        <div class=\"stats-container\" id=\"statsContainer\">\n            <div class=\"stat-card\">\n                <h3>总选秀球员</h3>\n                <div class=\"value\" id=\"totalPlayers\">0</div>\n            </div>\n            <div class=\"stat-card\">\n                <h3>总选秀次数</h3>\n                <div class=\"value\" id=\"totalDrafts\">0</div>\n            </div>\n            <div class=\"stat-card\">\n                <h3>参与球队</h3>\n                <div class=\"value\" id=\"totalTeams\">0</div>\n            </div>\n            <div class=\"stat-card\">\n                <h3>国际球员</h3>\n                <div class=\"value\" id=\"intlPlayers\">0</div>\n            </div>\n        </div>\n\n        <div class=\"filters\">\n            <div class=\"filters-grid\">\n                <div class=\"filter-group\">\n                    <label>年份</label>\n                    <select id=\"yearFilter\">\n                        <option value=\"\">全部年份</option>\n                        <option value=\"2024\">2024</option>\n                        <option value=\"2023\">2023</option>\n                        <option value=\"2022\">2022</option>\n                        <option value=\"2021\">2021</option>\n                        <option value=\"2020\">2020</option>\n                    </select>\n                </div>\n                <div class=\"filter-group\">\n                    <label>球队</label>\n                    <select id=\"teamFilter\">\n                        <option value=\"\">全部球队</option>\n                    </select>\n                </div>\n                <div class=\"filter-group\">\n                    <label>位置</label>\n                    <select id=\"positionFilter\">\n                        <option value=\"\">全部位置</option>\n                        <option value=\"PG\">控球后卫 (PG)</option>\n                        <option value=\"SG\">得分后卫 (SG)</option>\n                        <option value=\"SF\">小前锋 (SF)</option>\n                        <option value=\"PF\">大前锋 (PF)</option>\n                        <option value=\"C\">中锋 (C)</option>\n                    </select>\n                </div>\n                <div class=\"filter-group\">\n                    <label>搜索球员</label>\n                    <input type=\"text\" id=\"searchFilter\" placeholder=\"输入球员姓名...\">\n                </div>\n            </div>\n        </div>\n\n        <div class=\"table-container\">\n            <table>\n                <thead>\n                    <tr>\n                        <th data-sort=\"year\">年份 <span class=\"sort-icon\">↕</span></th>\n                        <th data-sort=\"round\">轮次 <span class=\"sort-icon\">↕</span></th>\n                        <th data-sort=\"pick\">选秀顺位 <span class=\"sort-icon\">↕</span></th>\n                        <th data-sort=\"player\">球员 <span class=\"sort-icon\">↕</span></th>\n                        <th data-sort=\"team\">球队 <span class=\"sort-icon\">↕</span></th>\n                        <th data-sort=\"position\">位置 <span class=\"sort-icon\">↕</span></th>\n                        <th data-sort=\"college\">大学/球队 <span class=\"sort-icon\">↕</span></th>\n                    </tr>\n                </thead>\n                <tbody id=\"tableBody\"></tbody>\n            </table>\n        </div>\n\n        <div class=\"pagination\">\n            <button id=\"prevBtn\">上一页</button>\n            <span class=\"page-info\" id=\"pageInfo\">第 1 页，共 1 页</span>\n            <button id=\"nextBtn\">下一页</button>\n        </div>\n    </div>\n\n    <script>\n        const draftData = [\n            { year: 2024, round: 1, pick: 1, player: \"Zaccharie Risacher\", team: \"Atlanta Hawks\", position: \"SF\", college: \"ALBA Berlin\" },\n            { year: 2024, round: 1, pick: 2, player: \"Alex Sarr\", team: \"Washington Wizards\", position: \"PF\", college: \"Metropolitans 92\" },\n            { year: 2024, round: 1, pick: 3, player: \"Reed Sheppard\", team: \"Houston Rockets\", position: \"PG\", college